{
    "name": "crynux-contracts",
    "version": "2.0.0",
    "type": "module",
    "scripts": {
        "compile": "hardhat compile",
        "deploy:l1:erc20-crynux-token": "hardhat ignition deploy ignition/modules/deploy-l1-erc20-crynux-token.ts --deployment-id deploy-l1-erc20-crynux-token",
        "deploy:l2:node-contracts": "hardhat ignition deploy ignition/modules/deploy-l2-node-contracts.ts --deployment-id deploy-l2-node-contracts",
        "deploy:emission:erc20": "hardhat ignition deploy ignition/modules/deploy-emission-erc20.ts --deployment-id deploy-emission-erc20",
        "execute:emission:erc20": "tsx deployments/base-sepolia/execute-emission.ts"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-toolbox-mocha-ethers": "3.0.5",
        "@openzeppelin/contracts": "5.0.2",
        "@prb/math": "^4.1.0",
        "ethers": "6.16.0",
        "hardhat": "3.4.5",
        "tsx": "4.22.1",
        "typescript": "6.0.3"
    },
    "dependencies": {
        "@arbitrum/chain-sdk": "^0.26.0",
        "viem": "^1.21.4"
    }
}
